# API base URL
# Dev (recommended): relative path — Vite proxies /api to Django on :8000
VITE_API_URL=/api/v1
# Dev (direct): call Django directly (shows :8000 in Network tab; CORS must allow :5173)
# VITE_API_URL=http://localhost:8000/api/v1

# GHL OAuth API (marketplace onboarding)
VITE_GHL_API_URL=/api/ghl

# Backend proxy target for Vite dev server
VITE_PROXY_TARGET=http://localhost:8000
